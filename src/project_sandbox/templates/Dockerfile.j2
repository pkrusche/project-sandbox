{% if source_dockerfile_text -%}
{{ source_dockerfile_text }}
{% else %}
FROM {{ base_image }}
{% endif %}
SHELL ["/bin/bash", "-lc"]
ARG AGENT_UID=1000
ARG AGENT_GID=1000

{% if source_dockerfile_text -%}
USER root
{% endif %}
RUN set -eux; \
    export DEBIAN_FRONTEND=noninteractive; \
    apt-get update; \
    apt-get install -y --no-install-recommends \
        ca-certificates curl git sudo gnupg jq xz-utils less \
        iptables ipset iproute2 dnsutils aggregate libatomic1; \
    rm -rf /var/lib/apt/lists/*

RUN set -eux; \
    if id -u agent >/dev/null 2>&1; then \
        userdel -r agent 2>/dev/null || userdel agent; \
    fi; \
    existing_uid_user="$(getent passwd "${AGENT_UID}" | cut -d: -f1 || true)"; \
    if [ -n "$existing_uid_user" ]; then \
        echo "WARNING: Removing existing UID ${AGENT_UID} user '$existing_uid_user'; project-sandbox uses that UID for agent."; \
        userdel -r "$existing_uid_user" 2>/dev/null || userdel "$existing_uid_user"; \
    fi; \
    existing_gid_group="$(getent group "${AGENT_GID}" | cut -d: -f1 || true)"; \
    agent_group_gid="$(getent group agent | cut -d: -f3 || true)"; \
    if [ -n "$agent_group_gid" ] && [ "$agent_group_gid" != "${AGENT_GID}" ]; then \
        groupdel agent; \
    fi; \
    if [ -z "$existing_gid_group" ]; then \
        groupadd -g "${AGENT_GID}" agent; \
    else \
        echo "WARNING: Reusing existing GID ${AGENT_GID} group '$existing_gid_group' for agent."; \
    fi; \
    useradd -m -u "${AGENT_UID}" -g "${AGENT_GID}" -s /bin/bash agent

RUN install -d /project-sandbox-config/claude /project-sandbox-config/codex \
        /project-sandbox-secrets/claude /project-sandbox-secrets/codex \
        /project-sandbox-secrets/opencode && \
    install -d -o agent -g "${AGENT_GID}" /home/agent/.claude /home/agent/.codex /home/agent/.config && \
    install -m 0644 -o agent -g "${AGENT_GID}" /dev/null /home/agent/.claude/settings.json && \
    install -m 0644 -o agent -g "${AGENT_GID}" /dev/null /home/agent/.codex/config.toml

# Node.js is pinned to an exact release and verified by SHA256 rather than
# piping the NodeSource installer through bash. To upgrade, bump NODE_VERSION
# and replace both per-architecture checksums with the values published in
# https://nodejs.org/dist/${NODE_VERSION}/SHASUMS256.txt.
RUN set -euxo pipefail; \
    NODE_VERSION="v26.4.0"; \
    NODE_ARCH="$(uname -m)"; \
    case "$NODE_ARCH" in \
        x86_64) NODE_ARCH="x64"; \
            NODE_SHA256="5c4286dcd5bbd5acb1ccc7eb0e088bd5eb1e3affad671ee9364004f8f6a4a431" ;; \
        aarch64|arm64) NODE_ARCH="arm64"; \
            NODE_SHA256="f6d8eedc52170667d45730ac2f413c4aa1e7cd2165c9cac5746ef3cb0f4ec45a" ;; \
        *) echo "Unsupported architecture for Node.js: $NODE_ARCH" >&2; exit 1 ;; \
    esac; \
    node_tmp="$(mktemp -d)"; \
    node_tarball="$node_tmp/node.tar.xz"; \
    curl -fsSL -o "$node_tarball" \
        "https://nodejs.org/dist/${NODE_VERSION}/node-${NODE_VERSION}-linux-${NODE_ARCH}.tar.xz"; \
    echo "${NODE_SHA256}  ${node_tarball}" | sha256sum -c -; \
    tar -xJf "$node_tarball" -C /usr/local --strip-components=1 \
        --exclude='*/CHANGELOG.md' --exclude='*/LICENSE' --exclude='*/README.md'; \
    rm -rf "$node_tmp"; \
    node --version; \
    npm --version

# jj is pinned to an exact release and the downloaded tarball is verified by
# SHA256 before extraction (no GitHub "latest release" follow). To upgrade,
# bump JJ_VERSION and replace both per-architecture checksums with the values
# from the matching release on https://github.com/jj-vcs/jj/releases.
RUN set -euxo pipefail; \
    JJ_VERSION="v0.42.0"; \
    JJ_ARCH="$(uname -m)"; \
    case "$JJ_ARCH" in \
        arm64|aarch64) JJ_ARCH="aarch64"; \
            JJ_SHA256="bc962ac57ec264541a62ed8492f080898380a277222b115e1ed96163196e6fc8" ;; \
        x86_64) JJ_ARCH="x86_64"; \
            JJ_SHA256="2d91e81d649e617a81608e7401ad1106029c15ece01ac928c4a351abef42be6a" ;; \
        *) echo "Unsupported architecture for jj: $JJ_ARCH" >&2; exit 1 ;; \
    esac; \
    jj_tmp="$(mktemp -d)"; \
    jj_tarball="$jj_tmp/jj-${JJ_VERSION}-${JJ_ARCH}-unknown-linux-musl.tar.gz"; \
    curl -fsSL -o "$jj_tarball" \
        "https://github.com/jj-vcs/jj/releases/download/${JJ_VERSION}/jj-${JJ_VERSION}-${JJ_ARCH}-unknown-linux-musl.tar.gz"; \
    echo "${JJ_SHA256}  ${jj_tarball}" | sha256sum -c -; \
    tar -xzf "$jj_tarball" -C "$jj_tmp"; \
    install -m 0755 "$jj_tmp/jj" /usr/local/bin/jj; \
    rm -rf "$jj_tmp"

# Global npm tooling is pinned to exact versions (never a floating tag) so a
# compromised or broken upstream release cannot silently land in an image that
# later receives workspace and agent credentials. Bump these deliberately.
RUN npm install -g @fission-ai/openspec@1.5.0

{% if install_claude %}
RUN npm install -g @anthropic-ai/claude-code@2.1.197
{% endif %}
{% if install_codex %}
RUN npm install -g @openai/codex@0.142.5
{% endif %}
{% if install_opencode %}
RUN npm install -g opencode-ai@1.17.13
{% endif %}

COPY {{ sandbox_copy_prefix }}{{ firewall_src_filename }} /usr/local/bin/project-sandbox-init-firewall
COPY {{ sandbox_copy_prefix }}entrypoint.sh /usr/local/bin/project-sandbox-entrypoint
COPY {{ sandbox_copy_prefix }}project-sandbox-devcontainer-init /usr/local/bin/project-sandbox-devcontainer-init

RUN chmod 0755 /usr/local/bin/project-sandbox-init-firewall \
    /usr/local/bin/project-sandbox-entrypoint \
    /usr/local/bin/project-sandbox-devcontainer-init && \
    echo 'agent ALL=(root) NOPASSWD: /usr/local/bin/project-sandbox-init-firewall' > /etc/sudoers.d/agent-firewall && \
    chmod 0440 /etc/sudoers.d/agent-firewall

USER agent
WORKDIR /workspace
ENTRYPOINT ["/usr/local/bin/project-sandbox-entrypoint"]
CMD ["bash"]
