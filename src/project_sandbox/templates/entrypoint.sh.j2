#!/bin/sh
set -eu

NAME="${PROJECT_SANDBOX_USER_NAME:-}"
EMAIL="${PROJECT_SANDBOX_USER_EMAIL:-}"

{% include "_provision.sh.j2" %}

if [ "${PROJECT_SANDBOX_NO_FIREWALL:-0}" != "1" ]; then
  if [ "${PROJECT_SANDBOX_QUIET:-0}" = "1" ]; then
    # Suppress the firewall banner, but capture output so a failure is still
    # visible (then abort, since the firewall is the sandbox boundary).
    if ! fw_out="$(sudo -n /usr/local/bin/project-sandbox-init-firewall 2>&1)"; then
      printf '%s\n' "$fw_out" >&2
      exit 1
    fi
  else
    sudo -n /usr/local/bin/project-sandbox-init-firewall
  fi
  export UV_OFFLINE=1
fi

load_project_sandbox_prompt() {
  mode="$1"
  if [ -z "${PROJECT_SANDBOX_PROMPT_FILE:-}" ]; then
    echo "ERROR: No prompt file provided for ${mode} mode." >&2
    return 2
  fi
  if [ ! -r "${PROJECT_SANDBOX_PROMPT_FILE}" ]; then
    echo "ERROR: Prompt file is not readable: ${PROJECT_SANDBOX_PROMPT_FILE}" >&2
    return 2
  fi
  PROMPT="$(cat "${PROJECT_SANDBOX_PROMPT_FILE}")"
  if [ -z "${PROMPT}" ]; then
    echo "ERROR: No prompt provided for ${mode} mode." >&2
    return 2
  fi
}

# When --verbose is requested, echo the coding agent's resolved config and the
# exact argv it is launched with (to stderr, so the stream-json stdout stays
# clean). This makes it visible whether --model / --effort actually reached the
# agent: a blank value here means the env var did not arrive.
log_project_sandbox_agent_command() {
  if [ "${PROJECT_SANDBOX_VERBOSE:-0}" != "1" ]; then
    return 0
  fi
  {
    printf 'project-sandbox: coding agent config:\n'
    printf '  model:  %s\n' "${PROJECT_SANDBOX_MODEL:-(agent default)}"
    printf '  effort: %s\n' "${PROJECT_SANDBOX_EFFORT:-(agent default)}"
    printf 'project-sandbox: coding agent command:'
    for _arg in "$@"; do
      printf ' %s' "$_arg"
    done
    printf '\n'
  } >&2
}

case "${1:-bash}" in
  project-sandbox-run)
    shift
    case "${1:-bash}" in
      claude)
        shift
        if [ -n "${PROJECT_SANDBOX_EFFORT:-}" ]; then
          set -- --effort "$PROJECT_SANDBOX_EFFORT" "$@"
        fi
        if [ -n "${PROJECT_SANDBOX_MODEL:-}" ]; then
          set -- --model "$PROJECT_SANDBOX_MODEL" "$@"
        fi
        log_project_sandbox_agent_command claude "$@"
        exec claude "$@"
        ;;
      codex)
        shift
        if [ -n "${PROJECT_SANDBOX_EFFORT:-}" ]; then
          set -- -c "model_reasoning_effort=\"$PROJECT_SANDBOX_EFFORT\"" "$@"
        fi
        if [ -n "${PROJECT_SANDBOX_MODEL:-}" ]; then
          set -- --model "$PROJECT_SANDBOX_MODEL" "$@"
        fi
        log_project_sandbox_agent_command codex "$@"
        exec codex "$@"
        ;;
      opencode)
        shift
        if [ -n "${PROJECT_SANDBOX_EFFORT:-}" ]; then
          set -- --variant "$PROJECT_SANDBOX_EFFORT" "$@"
        fi
        if [ -n "${PROJECT_SANDBOX_MODEL:-}" ]; then
          set -- --model "$PROJECT_SANDBOX_MODEL" "$@"
        fi
        log_project_sandbox_agent_command opencode "$@"
        exec opencode "$@"
        ;;
      pi)
        shift
        export PI_SKIP_VERSION_CHECK=1 PI_OFFLINE=1
        if [ -n "${PROJECT_SANDBOX_MODEL:-}" ]; then
          if [ -n "${PROJECT_SANDBOX_EFFORT:-}" ]; then
            set -- --model "${PROJECT_SANDBOX_MODEL}:${PROJECT_SANDBOX_EFFORT}" "$@"
          else
            set -- --model "${PROJECT_SANDBOX_MODEL}" "$@"
          fi
        fi
        log_project_sandbox_agent_command pi "$@"
        exec pi "$@"
        ;;
      bash) shift; exec bash "$@" ;;
      claude-headless)
        shift
        load_project_sandbox_prompt claude-headless || exit $?
        set -- -p "$PROMPT" --output-format stream-json --verbose --dangerously-skip-permissions
        if [ -n "${PROJECT_SANDBOX_EFFORT:-}" ]; then
          set -- --effort "$PROJECT_SANDBOX_EFFORT" "$@"
        fi
        if [ -n "${PROJECT_SANDBOX_MODEL:-}" ]; then
          set -- --model "$PROJECT_SANDBOX_MODEL" "$@"
        fi
        log_project_sandbox_agent_command claude "$@"
        exec claude "$@"
        ;;
      codex-headless)
        shift
        load_project_sandbox_prompt codex-headless || exit $?
        set -- --skip-git-repo-check --json --color never "$PROMPT"
        if [ -n "${PROJECT_SANDBOX_EFFORT:-}" ]; then
          set -- -c "model_reasoning_effort=\"$PROJECT_SANDBOX_EFFORT\"" "$@"
        fi
        if [ -n "${PROJECT_SANDBOX_MODEL:-}" ]; then
          set -- --model "$PROJECT_SANDBOX_MODEL" "$@"
        fi
        log_project_sandbox_agent_command codex exec "$@"
        exec codex exec "$@"
        ;;
      opencode-headless)
        shift
        load_project_sandbox_prompt opencode-headless || exit $?
        set -- "$PROMPT"
        if [ -n "${PROJECT_SANDBOX_EFFORT:-}" ]; then
          set -- --variant "$PROJECT_SANDBOX_EFFORT" "$@"
        fi
        if [ -n "${PROJECT_SANDBOX_MODEL:-}" ]; then
          set -- --model "$PROJECT_SANDBOX_MODEL" "$@"
        fi
        log_project_sandbox_agent_command opencode run "$@"
        exec opencode run "$@"
        ;;
      pi-headless)
        shift
        export PI_SKIP_VERSION_CHECK=1 PI_OFFLINE=1
        load_project_sandbox_prompt pi-headless || exit $?
        set -- -p "$PROMPT" --approve
        if [ -n "${PROJECT_SANDBOX_MODEL:-}" ]; then
          if [ -n "${PROJECT_SANDBOX_EFFORT:-}" ]; then
            set -- --model "${PROJECT_SANDBOX_MODEL}:${PROJECT_SANDBOX_EFFORT}" "$@"
          else
            set -- --model "${PROJECT_SANDBOX_MODEL}" "$@"
          fi
        fi
        log_project_sandbox_agent_command pi "$@"
        exec pi "$@"
        ;;
      bash-headless)
        shift
        load_project_sandbox_prompt bash-headless || exit $?
        exec bash -lc "$PROMPT"
        ;;
      *) exec "${@:-bash}" ;;
    esac ;;
  *) exec "$@" ;;
esac
