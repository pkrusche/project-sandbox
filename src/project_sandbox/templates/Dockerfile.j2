{% if source_dockerfile_text -%}
{{ source_dockerfile_text }}
{% else %}
FROM {{ base_image }}
{% endif %}
SHELL ["/bin/bash", "-lc"]

{% if source_dockerfile_text -%}
USER root
{% endif %}
RUN set -eux; \
    export DEBIAN_FRONTEND=noninteractive; \
    apt-get update; \
    apt-get install -y --no-install-recommends \
        ca-certificates curl git sudo gnupg jq xz-utils less \
        iptables ipset iproute2 dnsutils aggregate; \
    rm -rf /var/lib/apt/lists/*

RUN set -eux; \
    if id -u agent >/dev/null 2>&1; then \
        userdel -r agent 2>/dev/null || userdel agent; \
    fi; \
    existing_uid_user="$(getent passwd 1000 | cut -d: -f1 || true)"; \
    if [ -n "$existing_uid_user" ]; then \
        echo "WARNING: Removing existing UID 1000 user '$existing_uid_user'; project-sandbox uses UID 1000 for agent."; \
        userdel -r "$existing_uid_user" 2>/dev/null || userdel "$existing_uid_user"; \
    fi; \
    existing_gid_group="$(getent group 1000 | cut -d: -f1 || true)"; \
    if [ -n "$existing_gid_group" ]; then \
        echo "WARNING: Removing existing GID 1000 group '$existing_gid_group'; project-sandbox uses GID 1000 for agent."; \
        groupdel "$existing_gid_group" 2>/dev/null || true; \
    fi; \
    if getent group agent >/dev/null 2>&1; then \
        groupdel agent 2>/dev/null || true; \
    fi; \
    groupadd -g 1000 agent; \
    useradd -m -u 1000 -g agent -s /bin/bash agent

RUN install -d /project-sandbox-config/claude /project-sandbox-config/codex \
        /project-sandbox-secrets/claude /project-sandbox-secrets/codex \
        /project-sandbox-secrets/opencode && \
    install -d -o agent -g agent /home/agent/.claude /home/agent/.codex /home/agent/.config && \
    install -m 0644 -o agent -g agent /dev/null /home/agent/.claude/settings.json && \
    install -m 0644 -o agent -g agent /dev/null /home/agent/.codex/config.toml

RUN curl -fsSL https://deb.nodesource.com/setup_24.x | bash - && \
    apt-get update && apt-get install -y --no-install-recommends nodejs && \
    rm -rf /var/lib/apt/lists/*

RUN set -eux; \
    JJ_ARCH="$(uname -m)"; \
    case "$JJ_ARCH" in \
        arm64) JJ_ARCH="aarch64" ;; \
        aarch64|x86_64) ;; \
        *) echo "Unsupported architecture for jj: $JJ_ARCH" >&2; exit 1 ;; \
    esac; \
    JJ_VERSION="$(curl -fsSL https://api.github.com/repos/jj-vcs/jj/releases/latest | jq -r '.tag_name')"; \
    jj_tmp="$(mktemp -d)"; \
    curl -fsSL "https://github.com/jj-vcs/jj/releases/download/${JJ_VERSION}/jj-${JJ_VERSION}-${JJ_ARCH}-unknown-linux-musl.tar.gz" \
    | tar -xz -C "$jj_tmp"; \
    install -m 0755 "$jj_tmp/jj" /usr/local/bin/jj; \
    rm -rf "$jj_tmp"

{% if install_claude %}
RUN npm install -g @anthropic-ai/claude-code
{% endif %}
{% if install_codex %}
RUN npm install -g @openai/codex
{% endif %}
{% if install_opencode %}
RUN npm install -g opencode-ai
{% endif %}

COPY {{ sandbox_copy_prefix }}{{ firewall_src_filename }} /usr/local/bin/project-sandbox-init-firewall
COPY {{ sandbox_copy_prefix }}entrypoint.sh /usr/local/bin/project-sandbox-entrypoint
COPY {{ sandbox_copy_prefix }}project-sandbox-devcontainer-init /usr/local/bin/project-sandbox-devcontainer-init

RUN chmod 0755 /usr/local/bin/project-sandbox-init-firewall \
    /usr/local/bin/project-sandbox-entrypoint \
    /usr/local/bin/project-sandbox-devcontainer-init && \
    echo 'agent ALL=(root) NOPASSWD: /usr/local/bin/project-sandbox-init-firewall' > /etc/sudoers.d/agent-firewall && \
    chmod 0440 /etc/sudoers.d/agent-firewall

USER agent
WORKDIR /workspace
ENTRYPOINT ["/usr/local/bin/project-sandbox-entrypoint"]
CMD ["bash"]
