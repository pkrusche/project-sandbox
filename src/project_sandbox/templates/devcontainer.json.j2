{
  "name": "{{ project_name }} (project-sandbox)",
  "build": {
    "dockerfile": "{{ dockerfile_ref }}",
    "context": "{{ build_context_ref }}"
  },
  "runArgs": [
{% if firewall_enabled %}
    "--cap-add=NET_ADMIN",
    "--cap-add=NET_RAW"{% if memory or cpus %},{% endif %}
{% endif %}
{% if memory %}
    "--memory={{ memory }}"{% if cpus %},{% endif %}
{% endif %}
{% if cpus %}
    "--cpus={{ cpus }}"
{% endif %}
  ],
  "workspaceMount": "source=${localWorkspaceFolder},target=/workspace,type=bind,consistency=delegated",
  "workspaceFolder": "/workspace",
  "remoteUser": "agent",
  "containerEnv": {
    "CLAUDE_CONFIG_DIR": "/home/agent/.claude",
    "CODEX_HOME": "/home/agent/.codex",
    "NODE_OPTIONS": "--max-old-space-size=4096"
  },
  "remoteEnv": {
    "PROJECT_SANDBOX_USER_NAME": "{{ user_name }}",
    "PROJECT_SANDBOX_USER_EMAIL": "{{ user_email }}"
  },
  "mounts": [
    "source={{ claude_settings_mount }},target=/home/agent/.claude/settings.json,type=bind,readonly",
    "source={{ codex_config_mount }},target=/home/agent/.codex/config.toml,type=bind,readonly"{% if mount_claude_host %},
    "source=${localEnv:HOME}/.claude,target=/home/agent/.claude.host,type=bind,readonly"{% endif %}{% if mount_codex_host %},
    "source=${localEnv:HOME}/.codex,target=/home/agent/.codex.host,type=bind,readonly"{% endif %}{% if mount_opencode_host %},
    "source=${localEnv:HOME}/.config/opencode,target=/home/agent/.config/opencode.host,type=bind,readonly"{% endif %}{% if mount_copilot_host %},
    "source=${localEnv:HOME}/.copilot,target=/home/agent/.copilot.host,type=bind,readonly"{% endif %}{% for m in extra_mounts %},
    "{{ m }}"{% endfor %}
  ],
  "postStartCommand": "{% if firewall_enabled %}sudo /usr/local/bin/project-sandbox-init-firewall && {% endif %}/usr/local/bin/project-sandbox-devcontainer-init",
  "waitFor": "postStartCommand",
  "customizations": {
    "vscode": {
      "extensions": [
        "anthropic.claude-code",
        "openai.codex-vscode"
      ],
      "settings": {
        "terminal.integrated.defaultProfile.linux": "bash"
      }
    }
  },
  "features": {}{% if cpus or memory %},
  "hostRequirements": {
{% if cpus %}    "cpus": {{ cpus }}{% if memory %},
{% endif %}{% endif %}{% if memory %}    "memory": "{{ memory | replace('g', '') }}gb"
{% endif %}  }{% endif %}
}
