#!/bin/sh
set -eu

NAME="${PROJECT_SANDBOX_USER_NAME:-}"
EMAIL="${PROJECT_SANDBOX_USER_EMAIL:-}"

if [ -n "$NAME" ] || [ -n "$EMAIL" ]; then
  : > "$HOME/.gitconfig"
  [ -n "$NAME" ] && git config --global user.name "$NAME"
  [ -n "$EMAIL" ] && git config --global user.email "$EMAIL"
fi

if command -v jj >/dev/null 2>&1 && { [ -n "$NAME" ] || [ -n "$EMAIL" ]; }; then
  [ -n "$NAME" ] && (cd "$HOME" && jj config set --user user.name "$NAME")
  [ -n "$EMAIL" ] && (cd "$HOME" && jj config set --user user.email "$EMAIL")
fi

mkdir -p "$HOME/.claude" "$HOME/.codex" "$HOME/.copilot" "$HOME/.config/opencode"
if [ -f "/project-sandbox-config/claude/settings.json" ]; then
  cp "/project-sandbox-config/claude/settings.json" "$HOME/.claude/settings.json"
fi
if [ -f "/project-sandbox-config/claude/.credentials.json" ]; then
  cp "/project-sandbox-config/claude/.credentials.json" "$HOME/.claude/.credentials.json"
  chmod 600 "$HOME/.claude/.credentials.json"
fi
if [ -f "/project-sandbox-config/claude/.claude.json" ]; then
  cp "/project-sandbox-config/claude/.claude.json" "$HOME/.claude.json"
  chmod 600 "$HOME/.claude.json"
fi
if [ -f "/project-sandbox-config/codex/config.toml" ]; then
  cp "/project-sandbox-config/codex/config.toml" "$HOME/.codex/config.toml"
fi
if [ -f "$HOME/.claude.host/.credentials.json" ]; then
  cp "$HOME/.claude.host/.credentials.json" "$HOME/.claude/.credentials.json"
  chmod 600 "$HOME/.claude/.credentials.json"
fi
if [ -f "$HOME/.codex.host/auth.json" ]; then
  cp "$HOME/.codex.host/auth.json" "$HOME/.codex/auth.json"
  chmod 600 "$HOME/.codex/auth.json"
fi
if [ -d "$HOME/.copilot.host" ]; then
  cp -R "$HOME/.copilot.host/." "$HOME/.copilot/"
fi
if [ -d "$HOME/.config/opencode.host" ]; then
  cp -R "$HOME/.config/opencode.host/." "$HOME/.config/opencode/"
fi

if [ "${PROJECT_SANDBOX_NO_FIREWALL:-0}" != "1" ]; then
  sudo -n /usr/local/bin/project-sandbox-init-firewall
fi

case "${1:-bash}" in
  project-sandbox-run)
    shift
    case "${1:-bash}" in
      claude) shift; exec claude "$@" ;;
      codex) shift; exec codex "$@" ;;
      opencode) shift; exec opencode "$@" ;;
      copilot) shift; exec copilot "$@" ;;
      bash) shift; exec bash "$@" ;;
      claude-headless)
        shift
        if [ -n "${PROJECT_SANDBOX_PROMPT_FILE:-}" ] && [ -r "${PROJECT_SANDBOX_PROMPT_FILE}" ]; then
          exec claude -p "$(cat "$PROJECT_SANDBOX_PROMPT_FILE")" --output-format stream-json --dangerously-skip-permissions
        elif [ -n "${PROJECT_SANDBOX_PROMPT_FILE:-}" ]; then
          echo "ERROR: Prompt file is not readable: ${PROJECT_SANDBOX_PROMPT_FILE}" >&2
          exit 2
        elif [ -z "${PROJECT_SANDBOX_PROMPT:-}" ]; then
          echo "ERROR: No prompt provided for claude-headless mode." >&2
          exit 2
        fi
        exec claude -p "${PROJECT_SANDBOX_PROMPT:-}" --output-format stream-json --dangerously-skip-permissions
        ;;
      codex-headless)
        shift
        if [ -n "${PROJECT_SANDBOX_PROMPT_FILE:-}" ] && [ -r "${PROJECT_SANDBOX_PROMPT_FILE}" ]; then
          PROMPT="$(cat "${PROJECT_SANDBOX_PROMPT_FILE}")"
        elif [ -n "${PROJECT_SANDBOX_PROMPT_FILE:-}" ]; then
          echo "ERROR: Prompt file is not readable: ${PROJECT_SANDBOX_PROMPT_FILE}" >&2
          exit 2
        else
          PROMPT="${PROJECT_SANDBOX_PROMPT:-}"
        fi
        if [ -z "${PROMPT}" ]; then
          echo "ERROR: No prompt provided for codex-headless mode." >&2
          exit 2
        fi
        exec codex exec "$PROMPT"
        ;;
      opencode-headless)
        shift
        if [ -n "${PROJECT_SANDBOX_PROMPT_FILE:-}" ] && [ -r "${PROJECT_SANDBOX_PROMPT_FILE}" ]; then
          PROMPT="$(cat "${PROJECT_SANDBOX_PROMPT_FILE}")"
        elif [ -n "${PROJECT_SANDBOX_PROMPT_FILE:-}" ]; then
          echo "ERROR: Prompt file is not readable: ${PROJECT_SANDBOX_PROMPT_FILE}" >&2
          exit 2
        else
          PROMPT="${PROJECT_SANDBOX_PROMPT:-}"
        fi
        if [ -z "${PROMPT}" ]; then
          echo "ERROR: No prompt provided for opencode-headless mode." >&2
          exit 2
        fi
        exec opencode run "$PROMPT"
        ;;
      copilot-headless)
        shift
        if [ -n "${PROJECT_SANDBOX_PROMPT_FILE:-}" ] && [ -r "${PROJECT_SANDBOX_PROMPT_FILE}" ]; then
          PROMPT="$(cat "${PROJECT_SANDBOX_PROMPT_FILE}")"
        elif [ -n "${PROJECT_SANDBOX_PROMPT_FILE:-}" ]; then
          echo "ERROR: Prompt file is not readable: ${PROJECT_SANDBOX_PROMPT_FILE}" >&2
          exit 2
        else
          PROMPT="${PROJECT_SANDBOX_PROMPT:-}"
        fi
        if [ -z "${PROMPT}" ]; then
          echo "ERROR: No prompt provided for copilot-headless mode." >&2
          exit 2
        fi
        exec copilot --headless --prompt "$PROMPT"
        ;;
      bash-headless)
        shift
        if [ -n "${PROJECT_SANDBOX_PROMPT_FILE:-}" ] && [ -r "${PROJECT_SANDBOX_PROMPT_FILE}" ]; then
          PROMPT="$(cat "${PROJECT_SANDBOX_PROMPT_FILE}")"
        elif [ -n "${PROJECT_SANDBOX_PROMPT_FILE:-}" ]; then
          echo "ERROR: Prompt file is not readable: ${PROJECT_SANDBOX_PROMPT_FILE}" >&2
          exit 2
        else
          PROMPT="${PROJECT_SANDBOX_PROMPT:-}"
        fi
        if [ -z "${PROMPT}" ]; then
          echo "ERROR: No prompt provided for bash-headless mode." >&2
          exit 2
        fi
        exec bash -lc "$PROMPT"
        ;;
      *) exec "${@:-bash}" ;;
    esac ;;
  *) exec "$@" ;;
esac
