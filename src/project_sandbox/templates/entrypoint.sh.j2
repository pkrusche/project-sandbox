#!/bin/sh
set -eu

NAME="${PROJECT_SANDBOX_USER_NAME:-}"
EMAIL="${PROJECT_SANDBOX_USER_EMAIL:-}"

{% include "_provision.sh.j2" %}

if [ "${PROJECT_SANDBOX_NO_FIREWALL:-0}" != "1" ]; then
  if [ "${PROJECT_SANDBOX_QUIET:-0}" = "1" ]; then
    # Suppress the firewall banner, but capture output so a failure is still
    # visible (then abort, since the firewall is the sandbox boundary).
    if ! fw_out="$(sudo -n /usr/local/bin/project-sandbox-init-firewall 2>&1)"; then
      printf '%s\n' "$fw_out" >&2
      exit 1
    fi
  else
    sudo -n /usr/local/bin/project-sandbox-init-firewall
  fi
  export UV_OFFLINE=1
fi

load_project_sandbox_prompt() {
  mode="$1"
  if [ -z "${PROJECT_SANDBOX_PROMPT_FILE:-}" ]; then
    echo "ERROR: No prompt file provided for ${mode} mode." >&2
    return 2
  fi
  if [ ! -r "${PROJECT_SANDBOX_PROMPT_FILE}" ]; then
    echo "ERROR: Prompt file is not readable: ${PROJECT_SANDBOX_PROMPT_FILE}" >&2
    return 2
  fi
  PROMPT="$(cat "${PROJECT_SANDBOX_PROMPT_FILE}")"
  if [ -z "${PROMPT}" ]; then
    echo "ERROR: No prompt provided for ${mode} mode." >&2
    return 2
  fi
}

case "${1:-bash}" in
  project-sandbox-run)
    shift
    case "${1:-bash}" in
      claude) shift; exec claude "$@" ;;
      codex) shift; exec codex "$@" ;;
      opencode) shift; exec opencode "$@" ;;
      bash) shift; exec bash "$@" ;;
      claude-headless)
        shift
        load_project_sandbox_prompt claude-headless || exit $?
        if [ -n "${PROJECT_SANDBOX_MODEL:-}" ]; then
          exec claude --model "$PROJECT_SANDBOX_MODEL" -p "$PROMPT" --output-format stream-json --verbose --dangerously-skip-permissions
        fi
        exec claude -p "$PROMPT" --output-format stream-json --verbose --dangerously-skip-permissions
        ;;
      codex-headless)
        shift
        load_project_sandbox_prompt codex-headless || exit $?
        if [ -n "${PROJECT_SANDBOX_MODEL:-}" ]; then
          exec codex exec --model "$PROJECT_SANDBOX_MODEL" --json --color never "$PROMPT"
        fi
        exec codex exec --json --color never "$PROMPT"
        ;;
      opencode-headless)
        shift
        load_project_sandbox_prompt opencode-headless || exit $?
        if [ -n "${PROJECT_SANDBOX_MODEL:-}" ]; then
          exec opencode run --model "$PROJECT_SANDBOX_MODEL" "$PROMPT"
        fi
        exec opencode run "$PROMPT"
        ;;
      bash-headless)
        shift
        load_project_sandbox_prompt bash-headless || exit $?
        exec bash -lc "$PROMPT"
        ;;
      *) exec "${@:-bash}" ;;
    esac ;;
  *) exec "$@" ;;
esac
