FROM {{ base_image }}

SHELL ["/bin/bash", "-lc"]

RUN set -eux; \
    export DEBIAN_FRONTEND=noninteractive; \
    apt-get update; \
    apt-get install -y --no-install-recommends \
        ca-certificates curl git sudo gnupg jq xz-utils less \
        iptables ipset iproute2 dnsutils aggregate; \
    rm -rf /var/lib/apt/lists/*

RUN useradd -m -u 1000 -s /bin/bash agent

{% if install_claude or install_codex %}
RUN curl -fsSL https://deb.nodesource.com/setup_20.x | bash - && \
    apt-get update && apt-get install -y --no-install-recommends nodejs && \
    rm -rf /var/lib/apt/lists/*
{% endif %}

{% if install_claude %}
RUN npm install -g @anthropic-ai/claude-code
{% endif %}
{% if install_codex %}
RUN npm install -g @openai/codex
{% endif %}

COPY init-firewall.sh /usr/local/bin/project-sandbox-init-firewall
COPY entrypoint.sh /usr/local/bin/project-sandbox-entrypoint
COPY project-sandbox-devcontainer-init /usr/local/bin/project-sandbox-devcontainer-init

RUN chmod 0755 /usr/local/bin/project-sandbox-init-firewall \
    /usr/local/bin/project-sandbox-entrypoint \
    /usr/local/bin/project-sandbox-devcontainer-init && \
    echo 'agent ALL=(root) NOPASSWD: /usr/local/bin/project-sandbox-init-firewall' > /etc/sudoers.d/agent-firewall && \
    chmod 0440 /etc/sudoers.d/agent-firewall

USER agent
WORKDIR /workspace
ENTRYPOINT ["/usr/local/bin/project-sandbox-entrypoint"]
CMD ["bash"]
