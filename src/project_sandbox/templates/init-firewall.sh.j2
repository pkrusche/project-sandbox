#!/bin/bash
set -euo pipefail

# Collect all IPv4 and IPv6 nameservers
mapfile -t DNS4_LIST < <(awk '/^nameserver/ && $2 !~ /:/ {print $2}' /etc/resolv.conf)
mapfile -t DNS6_LIST < <(awk '/^nameserver/ && $2 ~ /:/  {print $2}' /etc/resolv.conf)
# Fallback if no IPv4 resolver found
[ -z "${DNS4_LIST[0]+x}" ] && DNS4_LIST=("127.0.0.11")

IPV6_FW=1
if ! ip6tables -L >/dev/null 2>&1; then
  if sysctl -w net.ipv6.conf.all.disable_ipv6=1 \
             net.ipv6.conf.default.disable_ipv6=1 \
             net.ipv6.conf.lo.disable_ipv6=1 >/dev/null 2>&1 \
     && [ "$(cat /proc/sys/net/ipv6/conf/all/disable_ipv6 2>/dev/null)" = "1" ]; then
    IPV6_FW=0
  else
    echo "ERROR: ip6tables unavailable and sysctl fallback failed."
    exit 1
  fi
fi

# Capture any existing DNS NAT rules (e.g. Docker's embedded resolver redirect)
# so they can be re-applied after the flush below. Only append real matches:
# appending a bare newline per resolver made NAT4/NAT6 look non-empty even when
# nothing matched, which then forced the restore below to run on empty input.
NAT4=""
for dns in "${DNS4_LIST[@]}"; do
  match=$(iptables-save -t nat 2>/dev/null | grep -- "$dns" || true)
  [ -n "$match" ] && NAT4+="$match"$'\n'
done
NAT6=""
if [ "$IPV6_FW" = "1" ]; then
  for dns6 in "${DNS6_LIST[@]}"; do
    match=$(ip6tables-save -t nat 2>/dev/null | grep -- "$dns6" || true)
    [ -n "$match" ] && NAT6+="$match"$'\n'
  done
fi

iptables -F; iptables -X
iptables -t nat -F; iptables -t nat -X
iptables -t mangle -F; iptables -t mangle -X
ipset destroy allowed-ipv4 2>/dev/null || true

if [ "$IPV6_FW" = "1" ]; then
  ip6tables -F; ip6tables -X
  ip6tables -t nat -F 2>/dev/null || true; ip6tables -t nat -X 2>/dev/null || true
  ip6tables -t mangle -F; ip6tables -t mangle -X
  ipset destroy allowed-ipv6 2>/dev/null || true
fi

# Re-apply the preserved NAT rules wrapped in a *nat/COMMIT block so
# iptables-restore can parse them. The previous "-t nat" is not a valid
# iptables-restore option (the table flag there is "-T"); it made the tool treat
# "nat" as an input filename and fail with "Can't open nat: No such file or
# directory". Kept non-fatal so a missing/limited nat table (e.g. the
# apple/container guest kernel) never aborts the filter-based egress firewall.
[ -n "$NAT4" ] && printf '*nat\n%sCOMMIT\n' "$NAT4" | iptables-restore --noflush 2>/dev/null || true
[ "$IPV6_FW" = "1" ] && [ -n "$NAT6" ] && printf '*nat\n%sCOMMIT\n' "$NAT6" | ip6tables-restore --noflush 2>/dev/null || true

iptables -A INPUT -i lo -j ACCEPT
iptables -A OUTPUT -o lo -j ACCEPT
# NOTE: outbound DNS to the resolver is intentionally NOT opened here.
# Allowlisted names are pre-resolved into /etc/hosts below and general
# outbound DNS is dropped (see "Block general outbound DNS") to prevent
# DNS-tunnel exfiltration of data to arbitrary names via the resolver.

if [ "$IPV6_FW" = "1" ]; then
  ip6tables -A INPUT -i lo -j ACCEPT
  ip6tables -A OUTPUT -o lo -j ACCEPT
  # ICMPv6 is required for IPv6 to function, but a blanket accept lets data
  # ride arbitrary ICMPv6 to any host. Allow only the control types actually
  # needed: error / PMTU messages (types 1-4, left unrestricted because a
  # Packet Too Big can legitimately originate from any on-path router) and
  # neighbor / router discovery (types 133-137), the latter confined to
  # link-local unicast (fe80::/10) and link-local multicast (ff02::/16) so it
  # cannot carry data to off-link / global destinations.
  for icmp6_type in 1 2 3 4; do
    ip6tables -A INPUT  -p ipv6-icmp --icmpv6-type "$icmp6_type" -j ACCEPT
    ip6tables -A OUTPUT -p ipv6-icmp --icmpv6-type "$icmp6_type" -j ACCEPT
  done
  for icmp6_type in 133 134 135 136 137; do
    for ll_scope in fe80::/10 ff02::/16; do
      ip6tables -A INPUT  -p ipv6-icmp --icmpv6-type "$icmp6_type" -s "$ll_scope" -j ACCEPT
      ip6tables -A OUTPUT -p ipv6-icmp --icmpv6-type "$icmp6_type" -d "$ll_scope" -j ACCEPT
    done
  done
  # Outbound DNS over IPv6 is dropped below alongside IPv4 (see "Block general
  # outbound DNS"); allowlisted names are pre-resolved into /etc/hosts.
fi

ipset create allowed-ipv4 hash:net family inet
[ "$IPV6_FW" = "1" ] && ipset create allowed-ipv6 hash:net family inet6

gh_meta=$(curl -sf --max-time 10 https://api.github.com/meta || true)
[ -z "$gh_meta" ] && gh_meta='{"web":[],"api":[],"git":[],"ipv6":[]}'

while IFS= read -r cidr; do
  [ -n "$cidr" ] && ipset add --exist allowed-ipv4 "$cidr"
done < <(echo "$gh_meta" | jq -r '(.web + .api + .git)[]' | aggregate -q 2>/dev/null || true)

if [ "$IPV6_FW" = "1" ]; then
  while IFS= read -r cidr6; do
    [ -n "$cidr6" ] && ipset add --exist allowed-ipv6 "$cidr6" 2>/dev/null || true
  done < <(echo "$gh_meta" | jq -r '.ipv6[]?' 2>/dev/null || true)
fi

DOMAINS=(
  "api.anthropic.com"
  "claude.ai"
  "code.claude.com"
  "platform.claude.com"
  "api.openai.com"
  "auth.openai.com"
  "chatgpt.com"
{% for domain in extra_domains %}
  {{ domain | shlex_quote }}
{% endfor %}
)

# Pre-resolve the allowlisted domains and pin each result into /etc/hosts so
# name resolution keeps working after general outbound DNS is dropped below.
# Strip any pins from a previous run first to stay idempotent.
sed -i '/# project-sandbox-dns-pin/d' /etc/hosts 2>/dev/null || true

for domain in "${DOMAINS[@]}"; do
  while IFS= read -r ip4; do
    [[ "$ip4" =~ ^[0-9]+\.[0-9]+\.[0-9]+\.[0-9]+$ ]] || continue
    ipset add --exist allowed-ipv4 "$ip4"
    printf '%s\t%s # project-sandbox-dns-pin\n' "$ip4" "$domain" >> /etc/hosts
  done < <(dig +noall +answer +time=5 A "$domain" 2>/dev/null | awk '$4=="A" {print $5}' || true)

  if [ "$IPV6_FW" = "1" ]; then
    while IFS= read -r ip6; do
      [[ "$ip6" =~ : ]] || continue
      ipset add --exist allowed-ipv6 "$ip6" 2>/dev/null || true
      printf '%s\t%s # project-sandbox-dns-pin\n' "$ip6" "$domain" >> /etc/hosts
    done < <(dig +noall +answer +time=5 AAAA "$domain" 2>/dev/null | awk '$4=="AAAA" {print $5}' || true)
  fi
done

{% if allow_host_network %}
# ============================================================
# Host gateway (port-forwarding / IDE attach)
# ============================================================
# Allow only the default gateway address (not the whole interface CIDR), so
# peers sharing the container subnet are not reachable. Mirrors the IPv6 path.
HOST_GW4=$(ip -4 route | awk '/default/ {print $3; exit}') || true
HOST_IF4=$(ip -4 route | awk '/default/ {print $5; exit}') || true
if [ -n "$HOST_GW4" ]; then
  echo "Allowing host gateway (IPv4): $HOST_GW4"
  iptables -A OUTPUT -d "$HOST_GW4" -o "${HOST_IF4:-eth0}" -j ACCEPT
  iptables -A INPUT  -s "$HOST_GW4" -i "${HOST_IF4:-eth0}" -j ACCEPT
fi

if [ "$IPV6_FW" = "1" ]; then
  HOST_GW6=$(ip -6 route | awk '/default/ {print $3; exit}') || true
  HOST_IF6=$(ip -6 route | awk '/default/ {print $5; exit}') || true
  if [ -n "$HOST_GW6" ]; then
    echo "Allowing host gateway (IPv6): $HOST_GW6"
    ip6tables -A OUTPUT -d "$HOST_GW6" -o "${HOST_IF6:-eth0}" -j ACCEPT
    ip6tables -A INPUT  -s "$HOST_GW6" -i "${HOST_IF6:-eth0}" -j ACCEPT
  fi
fi
{% endif %}

iptables -P INPUT DROP; iptables -P FORWARD DROP; iptables -P OUTPUT DROP
if [ "$IPV6_FW" = "1" ]; then
  ip6tables -P INPUT DROP; ip6tables -P FORWARD DROP; ip6tables -P OUTPUT DROP
fi

iptables -A INPUT -m state --state ESTABLISHED,RELATED -j ACCEPT
iptables -A OUTPUT -m state --state ESTABLISHED,RELATED -j ACCEPT
if [ "$IPV6_FW" = "1" ]; then
  ip6tables -A INPUT -m state --state ESTABLISHED,RELATED -j ACCEPT
  ip6tables -A OUTPUT -m state --state ESTABLISHED,RELATED -j ACCEPT
fi

# Block general outbound DNS. Allowlisted names are already pinned in
# /etc/hosts, so no runtime DNS is required; dropping it here (ahead of the
# allowlist ACCEPT, so it applies even if a resolver IP falls inside an
# allowlisted range) closes the DNS-tunnel exfiltration channel.
iptables -A OUTPUT -p udp --dport 53 -j DROP
iptables -A OUTPUT -p tcp --dport 53 -j DROP
if [ "$IPV6_FW" = "1" ]; then
  ip6tables -A OUTPUT -p udp --dport 53 -j DROP
  ip6tables -A OUTPUT -p tcp --dport 53 -j DROP
fi

iptables -A OUTPUT -m set --match-set allowed-ipv4 dst -j ACCEPT
[ "$IPV6_FW" = "1" ] && ip6tables -A OUTPUT -m set --match-set allowed-ipv6 dst -j ACCEPT

iptables -A OUTPUT -j REJECT --reject-with icmp-admin-prohibited
iptables -A INPUT -j REJECT --reject-with icmp-admin-prohibited
if [ "$IPV6_FW" = "1" ]; then
  ip6tables -A OUTPUT -j REJECT --reject-with icmp6-adm-prohibited
  ip6tables -A INPUT -j REJECT --reject-with icmp6-adm-prohibited
fi

echo "Firewall initialized."
printf "  IPv4 allowlist: %d entries\n" \
  "$(ipset list allowed-ipv4 2>/dev/null | grep -c '^[0-9]' || echo 0)"
if [ "$IPV6_FW" = "1" ]; then
  printf "  IPv6 allowlist: %d entries\n" \
    "$(ipset list allowed-ipv6 2>/dev/null | grep -c '^[0-9a-f]' || echo 0)"
else
  echo "  IPv6: disabled via sysctl"
fi
