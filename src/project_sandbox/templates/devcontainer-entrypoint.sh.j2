#!/bin/sh
set -eu

NAME="${PROJECT_SANDBOX_USER_NAME:-$(git config --global user.name 2>/dev/null || echo '')}"
EMAIL="${PROJECT_SANDBOX_USER_EMAIL:-$(git config --global user.email 2>/dev/null || echo '')}"

if [ -n "$NAME" ] || [ -n "$EMAIL" ]; then
  : > "$HOME/.gitconfig"
  [ -n "$NAME" ] && git config --global user.name "$NAME"
  [ -n "$EMAIL" ] && git config --global user.email "$EMAIL"
fi

if command -v jj >/dev/null 2>&1 && { [ -n "$NAME" ] || [ -n "$EMAIL" ]; }; then
  [ -n "$NAME" ] && (cd "$HOME" && jj config set --user user.name "$NAME")
  [ -n "$EMAIL" ] && (cd "$HOME" && jj config set --user user.email "$EMAIL")
fi

mkdir -p "$HOME/.claude" "$HOME/.codex" "$HOME/.copilot" "$HOME/.config/opencode"
if [ -f "/project-sandbox-config/claude/settings.json" ]; then
  cp "/project-sandbox-config/claude/settings.json" "$HOME/.claude/settings.json"
fi
if [ -f "/project-sandbox-config/claude/.credentials.json" ]; then
  cp "/project-sandbox-config/claude/.credentials.json" "$HOME/.claude/.credentials.json"
  chmod 600 "$HOME/.claude/.credentials.json"
fi
if [ -f "/project-sandbox-config/claude/.claude.json" ]; then
  cp "/project-sandbox-config/claude/.claude.json" "$HOME/.claude.json"
  chmod 600 "$HOME/.claude.json"
fi
if [ -f "/project-sandbox-config/codex/config.toml" ]; then
  cp "/project-sandbox-config/codex/config.toml" "$HOME/.codex/config.toml"
fi
if [ -f "$HOME/.claude.host/.credentials.json" ]; then
  cp "$HOME/.claude.host/.credentials.json" "$HOME/.claude/.credentials.json"
  chmod 600 "$HOME/.claude/.credentials.json"
fi
if [ -f "$HOME/.codex.host/auth.json" ]; then
  cp "$HOME/.codex.host/auth.json" "$HOME/.codex/auth.json"
  chmod 600 "$HOME/.codex/auth.json"
fi
if [ -d "$HOME/.copilot.host" ]; then
  cp -R "$HOME/.copilot.host/." "$HOME/.copilot/"
fi
if [ -d "$HOME/.config/opencode.host" ]; then
  cp -R "$HOME/.config/opencode.host/." "$HOME/.config/opencode/"
fi

echo "project-sandbox: devcontainer init complete."
