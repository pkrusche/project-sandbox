{% if source_dockerfile_text -%}
{{ source_dockerfile_text }}
{% else %}
FROM {{ base_image }}
{% endif %}
SHELL ["/bin/bash", "-lc"]

{% if source_dockerfile_text -%}
USER root
{% endif %}
RUN set -eux; \
    export DEBIAN_FRONTEND=noninteractive; \
    apt-get update; \
    apt-get install -y --no-install-recommends \
        ca-certificates curl git sudo gnupg jq xz-utils less \
        iptables ipset iproute2 dnsutils aggregate; \
    rm -rf /var/lib/apt/lists/*

RUN if ! id -u agent >/dev/null 2>&1; then \
        useradd -m -u 1000 -s /bin/bash agent; \
    fi

RUN curl -fsSL https://deb.nodesource.com/setup_24.x | bash - && \
    apt-get update && apt-get install -y --no-install-recommends nodejs && \
    rm -rf /var/lib/apt/lists/*

RUN JJ_ARCH=$(uname -m | sed 's/aarch64/aarch64/;s/x86_64/x86_64/') && \
    curl -fsSL "https://github.com/jj-vcs/jj/releases/latest/download/jj-${JJ_ARCH}-unknown-linux-musl.tar.gz" \
    | tar -xz -C /usr/local/bin jj && \
    chmod 0755 /usr/local/bin/jj

{% if install_claude %}
RUN npm install -g @anthropic-ai/claude-code
{% endif %}
{% if install_codex %}
RUN npm install -g @openai/codex
{% endif %}
{% if install_opencode %}
RUN npm install -g opencode-ai
{% endif %}
{% if install_copilot %}
RUN npm install -g @github/copilot
{% endif %}

COPY {{ sandbox_copy_prefix }}init-firewall.sh /usr/local/bin/project-sandbox-init-firewall
COPY {{ sandbox_copy_prefix }}entrypoint.sh /usr/local/bin/project-sandbox-entrypoint
COPY {{ sandbox_copy_prefix }}project-sandbox-devcontainer-init /usr/local/bin/project-sandbox-devcontainer-init

RUN chmod 0755 /usr/local/bin/project-sandbox-init-firewall \
    /usr/local/bin/project-sandbox-entrypoint \
    /usr/local/bin/project-sandbox-devcontainer-init && \
    echo 'agent ALL=(root) NOPASSWD: /usr/local/bin/project-sandbox-init-firewall' > /etc/sudoers.d/agent-firewall && \
    chmod 0440 /etc/sudoers.d/agent-firewall

USER agent
WORKDIR /workspace
ENTRYPOINT ["/usr/local/bin/project-sandbox-entrypoint"]
CMD ["bash"]
